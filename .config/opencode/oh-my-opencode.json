{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "background_task": {
      "defaultConcurrency": 3,
      "staleTimeoutMs": 180000,
      "providerConcurrency": { "github-copilot": 3 },
      "modelConcurrency": { "github-copilot/claude-opus-4.5": 2, "github-copilot/claude-sonnet-4.5": 2 , "github-copilot/gpt-5-mini": 3}
  },
  "tmux": {
      "enabled": true,
      "layout": "main-vertical",
      "main_pane_size": 60,
      "main_pane_min_width": 120,
      "agent_pane_min_width": 40
  },
  "disabled_mcps": ["websearch", "context7", "grep_app"],
  "hashline_edit": true,
  "agents": {
    "sisyphus": {
      "model": "github-copilot/claude-opus-4.5",
      "variant": "max"
    },
    "hephaestus": {
      "model": "github-copilot/claude-sonnet-4.5",
      "variant": "medium"
    },
    "oracle": {
      "model": "github-copilot/claude-sonnet-4.5",
      "variant": "high"
    },
    "librarian": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "explore": {
      "model": "github-copilot/gpt-5-mini"
    },
    "multimodal-looker": {
      "model": "github-copilot/gemini-3-flash-preview"
    },
    "prometheus": {
      "model": "github-copilot/claude-opus-4.5",
      "variant": "max"
    },
    "metis": {
      "model": "github-copilot/claude-opus-4.5",
      "variant": "max"
    },
    "momus": {
      "model": "github-copilot/claude-sonnet-4.5",
      "variant": "medium"
    },
    "atlas": {
      "model": "github-copilot/claude-sonnet-4.5"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "github-copilot/gemini-3-pro-preview",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "github-copilot/claude-sonnet-4.5",
      "variant": "xhigh"
    },
    "deep": {
      "model": "github-copilot/claude-sonnet-4.5",
      "variant": "medium"
    },
    "artistry": {
      "model": "github-copilot/gemini-3-pro-preview",
      "variant": "high"
    },
    "quick": {
      "model": "github-copilot/claude-haiku-4.5"
    },
    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "unspecified-high": {
      "model": "github-copilot/claude-sonnet-4.5"
    },
    "writing": {
      "model": "github-copilot/gemini-3-flash-preview"
    }
  }
}
