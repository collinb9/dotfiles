{
	"enabled": true,
	"network": {
		"allowedDomains": [
			"npmjs.org",
			"*.npmjs.org",
			"registry.npmjs.org",
			"registry.yarnpkg.com",
			"pypi.org",
			"*.pypi.org",
			"github.com",
			"*.github.com",
			"api.github.com",
			"raw.githubusercontent.com",
            "pi.dev"
		],
		"deniedDomains": []
	},
	"filesystem": {
		"denyRead": ["~/.ssh", "~/.aws", "~/.gnupg", "~/.docker/config.json", "~/*_history", ".env", "*.pem", "*.key", "~/Work/ec2_ssh", "~/.pgpass"],
		"allowWrite": [".", "/tmp"],
		"denyWrite": [".env", "*.pem", "*.key"]
	}
}
