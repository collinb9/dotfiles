#!/usr/bin/env sh

# Fuzzy find git directories and open a tmux session in the chosen one
# Based on/stolen from https://github.com/ThePrimeagen/.dotfiles

if [ $# -eq 1 ]; then
    selected=$1
else
    selected=$(find ~/Work ~/personal -mindepth 1 -maxdepth 3 -type d,f -name ".git"  | xargs -n1 dirname | fzf --height=~20)
fi

if [ -z $selected ]; then
    exit 0
fi

tsession $selected
